import SwiftUI
import AuthenticationServices
import AWSCognitoIdentity

@MainActor
class AppleSignInService: NSObject, ObservableObject {
    @Published var isAuthenticated = false
    @Published var currentUser: User?
    @Published var isLoading = false
    @Published var error: String?
    
    private let identityPoolId = "eu-west-1:PLACEHOLDER_IDENTITY_POOL_ID"
    private let apiBaseUrl = "https://PLACEHOLDER_API_GATEWAY_URL"
    
    struct User {
        let internalId: String
        let handle: String
        let name: String?
        let email: String?
        let cognitoIdentityId: String
    }
    
    func signInWithApple() {
        isLoading = true
        error = nil
        
        let request = ASAuthorizationAppleIDProvider().createRequest()
        request.requestedScopes = [.fullName, .email]
        
        let authController = ASAuthorizationController(authorizationRequests: [request])
        authController.delegate = self
        authController.presentationContextProvider = self
        authController.performRequests()
    }
    
    func signOut() {
        isAuthenticated = false
        currentUser = nil
        UserDefaults.standard.removeObject(forKey: "cognitoIdentityId")
        UserDefaults.standard.removeObject(forKey: "userProfile")
    }
    
    func completeRegistration(cognitoIdentityId: String, appleUserId: String, name: String, email: String, handle: String) async {
        isLoading = true
        error = nil
        
        do {
            let requestBody = [
                "cognitoIdentityId": cognitoIdentityId,
                "appleUserId": appleUserId,
                "name": name,
                "email": email,
                "handle": handle
            ]
            
            let jsonData = try JSONSerialization.data(withJSONObject: requestBody)
            
            var request = URLRequest(url: URL(string: "\(apiBaseUrl)/auth/complete")!)
            request.httpMethod = "POST"
            request.setValue("application/json", forHTTPHeaderField: "Content-Type")
            request.httpBody = jsonData
            
            let (data, response) = try await URLSession.shared.data(for: request)
            
            guard let httpResponse = response as? HTTPURLResponse else {
                throw NSError(domain: "NetworkError", code: 1)
            }
            
            if httpResponse.statusCode == 200 {
                let result = try JSONSerialization.jsonObject(with: data) as? [String: Any]
                let userData = result?["user"] as? [String: Any]
                
                let user = User(
                    internalId: userData?["internalId"] as? String ?? "",
                    handle: userData?["handle"] as? String ?? "",
                    name: userData?["name"] as? String,
                    email: userData?["email"] as? String,
                    cognitoIdentityId: cognitoIdentityId
                )
                
                storeUser(user)
                
                await MainActor.run {
                    self.currentUser = user
                    self.isAuthenticated = true
                    self.isLoading = false
                }
            } else if httpResponse.statusCode == 409 {
                await MainActor.run {
                    self.error = "Handle already taken"
                    self.isLoading = false
                }
            }
        } catch {
            await MainActor.run {
                self.error = "Registration failed"
                self.isLoading = false
            }
        }
    }
    
    private func storeUser(_ user: User) {
        UserDefaults.standard.set(user.cognitoIdentityId, forKey: "cognitoIdentityId")
        let userData = [
            "internalId": user.internalId,
            "handle": user.handle,
            "name": user.name ?? "",
            "email": user.email ?? "",
            "cognitoIdentityId": user.cognitoIdentityId
        ]
        UserDefaults.standard.set(userData, forKey: "userProfile")
    }
    
    private func loadStoredUser(cognitoIdentityId: String) -> User? {
        guard let storedId = UserDefaults.standard.string(forKey: "cognitoIdentityId"),
              storedId == cognitoIdentityId,
              let userData = UserDefaults.standard.dictionary(forKey: "userProfile") else {
            return nil
        }
        
        return User(
            internalId: userData["internalId"] as? String ?? "",
            handle: userData["handle"] as? String ?? "",
            name: userData["name"] as? String,
            email: userData["email"] as? String,
            cognitoIdentityId: userData["cognitoIdentityId"] as? String ?? ""
        )
    }
}

extension AppleSignInService: ASAuthorizationControllerDelegate {
    func authorizationController(controller: ASAuthorizationController, didCompleteWithAuthorization authorization: ASAuthorization) {
        guard let appleIDCredential = authorization.credential as? ASAuthorizationAppleIDCredential,
              let identityToken = appleIDCredential.identityToken else {
            error = "Failed to get Apple ID credential"
            isLoading = false
            return
        }
        
        // For now, simulate Cognito federation
        let cognitoIdentityId = "cognito-\(appleIDCredential.user)"
        
        // Check if user exists
        if let existingUser = loadStoredUser(cognitoIdentityId: cognitoIdentityId) {
            currentUser = existingUser
            isAuthenticated = true
            isLoading = false
        } else {
            // New user - show handle selection
            isLoading = false
            NotificationCenter.default.post(name: .showHandleSelection, object: [
                "cognitoIdentityId": cognitoIdentityId,
                "appleUserId": appleIDCredential.user,
                "name": appleIDCredential.fullName?.formatted() ?? "",
                "email": appleIDCredential.email ?? ""
            ])
        }
    }
    
    func authorizationController(controller: ASAuthorizationController, didCompleteWithError error: Error) {
        self.error = "Apple Sign In failed"
        isLoading = false
    }
}

extension AppleSignInService: ASAuthorizationControllerPresentationContextProviding {
    func presentationAnchor(for controller: ASAuthorizationController) -> ASPresentationAnchor {
        return UIApplication.shared.connectedScenes
            .compactMap { $0 as? UIWindowScene }
            .first?.windows
            .first { $0.isKeyWindow } ?? UIWindow()
    }
}

extension Notification.Name {
    static let showHandleSelection = Notification.Name("showHandleSelection")
}
